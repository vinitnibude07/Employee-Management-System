@inject IJSRuntime JS
@using EMS.Blazor.Models
@page "/register"
@rendermode InteractiveServer
@using EMS.Shared.DTOs
@using Microsoft.AspNetCore.Components.Forms

@inject NavigationManager Navigation
@inject EMS.Blazor.Services.AuthService AuthService

<div class="container-fluid min-vh-100 p-4 position-relative d-flex align-items-center justify-content-center"
     style="background: radial-gradient(circle at center, #1a2332 0%, #0d1117 100%) !important; font-family: 'Segoe UI', system-ui, sans-serif; color: #94a3b8; padding-bottom: 70px !important;">

    <div class="row justify-content-center w-100 my-auto">
        <div class="col-md-10 col-lg-8" style="max-width: 800px;">

            <div class="card border-0 rounded-4 shadow-2xl overflow-hidden shadow-lg"
                 style="background: linear-gradient(145deg, #232d3f 0%, #151b26 100%) !important;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7), inset 0 1px 1px rgba(255,255,255,0.1) !important;
                border: 1px solid rgba(0, 210, 255, 0.15) !important;">

                <div class="card-header border-0 p-4"
                     style="background: linear-gradient(180deg, rgba(35,45,63,0.8) 0%, rgba(21,27,38,0.4) 100%) !important;
                    border-bottom: 1px solid rgba(255,255,255,0.05) !important;">
                    <h3 class="mb-1 fw-bold text-white" style="letter-spacing: 0.5px; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">
                        New Registration
                    </h3>
                    <small style="color: #788fa6 !important; letter-spacing: 0.3px;">
                        Create a secure system profile to request workspace clearance
                    </small>
                </div>

                <div class="card-body p-4" style="background: transparent !important;">

                    <EditForm Model="@registerModel"
                              OnValidSubmit="RegisterUser"
                              FormName="RegisterForm">

                        <DataAnnotationsValidator />

                        <h5 class="text-white small tracking-wider fw-bold mb-3 uppercase" style="color: #00d2ff !important; letter-spacing: 1px;">
                            01. Identity Matrix
                        </h5>
                        <div class="row g-3 mb-4">
                            <div class="col-md-4">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">First Name<span style="color: #f87171; font-weight: bold; margin-left: 2px;">*</span></label>
                                <InputText class="form-control text-white px-3 py-2"
                                           style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                           @bind-Value="registerModel.FirstName" />
                                <ValidationMessage For="@(() => registerModel.FirstName)" class="small mt-1" style="color: #f87171;" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Middle Name</label>
                                <InputText class="form-control text-white px-3 py-2"
                                           style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                           @bind-Value="registerModel.MiddleName" />
                                <ValidationMessage For="@(() => registerModel.MiddleName)" class="small mt-1" style="color: #f87171;" />
                            </div>

                            <div class="col-md-4">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Last Name<span style="color: #f87171; font-weight: bold; margin-left: 2px;">*</span></label>
                                <InputText class="form-control text-white px-3 py-2"
                                           style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                           @bind-Value="registerModel.LastName" />
                                <ValidationMessage For="@(() => registerModel.LastName)" class="small mt-1" style="color: #f87171;" />
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Email Address<span style="color: #f87171; font-weight: bold; margin-left: 2px;">*</span></label>
                                <InputText class="form-control text-white px-3 py-2"
                                           style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                           placeholder="name@company.com"
                                           @bind-Value="registerModel.Email" />
                                <ValidationMessage For="@(() => registerModel.Email)" class="small mt-1" style="color: #f87171;" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Phone Number<span style="color: #f87171; font-weight: bold; margin-left: 2px;">*</span></label>
                                <InputText class="form-control text-white px-3 py-2"
                                           style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                           placeholder="+91 XXXXX XXXXX"
                                           @bind-Value="registerModel.PhoneNumber" />
                                <ValidationMessage For="@(() => registerModel.PhoneNumber)" class="small mt-1" style="color: #f87171;" />
                            </div>
                        </div>

                        <h5 class="text-white small tracking-wider fw-bold mb-3 mt-4 uppercase" style="color: #00d2ff !important; letter-spacing: 1px;">
                            02. Location Matrix
                        </h5>

                        <div class="mb-3">
                            <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Permanent Address<span style="color: #f87171; font-weight: bold; margin-left: 2px;">*</span></label>
                            <InputText class="form-control text-white px-3 py-2"
                                       style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                       @bind-Value="registerModel.PermanentAddress" />
                            <ValidationMessage For="@(() => registerModel.PermanentAddress)" class="small mt-1" style="color: #f87171;" />
                        </div>

                        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-3 p-3 rounded-3"
                             style="background: rgba(0,0,0,0.15); border: 1px solid rgba(255,255,255,0.02);">

                            <div class="form-check d-flex align-items-center gap-2 m-0">
                                <input type="checkbox"
                                       class="form-check-input mt-0"
                                       style="background-color: #111722; border-color: #2e3d54; width: 18px; height: 18px; cursor: pointer;"
                                       @bind="sameAddress" />
                                <label class="form-check-label small fw-semibold text-white ms-1" style="cursor: pointer;">
                                    Current Address Same As Permanent Address
                                </label>
                            </div>

                            <button type="button"
                                    class="btn btn-sm text-white px-3 py-2"
                                    style="background: #192230 !important; border: 1px solid #3d516b !important; font-size: 0.85rem; border-radius: 6px;"
                                    @onclick="GetLocation">
                                🛰️ Sync GPS Matrix
                            </button>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(locationMessage))
                        {
                            <div class="alert border-0 small rounded-3 mb-3"
                                 style="background: rgba(0, 210, 255, 0.1); color: #00d2ff; border: 1px solid rgba(0, 210, 255, 0.2) !important;" role="alert">
                                📡 Tracking telemetry: @locationMessage
                            </div>
                        }

                        <div class="mb-4">
                            <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Current Address<span style="color: #f87171; font-weight: bold; margin-left: 2px;">*</span></label>
                            <InputText class="form-control text-white px-3 py-2"
                                       style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                       @bind-Value="registerModel.CurrentAddress" />
                            <ValidationMessage For="@(() => registerModel.CurrentAddress)" class="small mt-1" style="color: #f87171;" />
                        </div>

                        <h5 class="text-white small tracking-wider fw-bold mb-3 mt-4 uppercase" style="color: #00d2ff !important; letter-spacing: 1px;">
                            03. Security Node Clearance
                        </h5>
                        <div class="mb-3">
                            <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Username<span style="color: #f87171; font-weight: bold; margin-left: 2px;">*</span></label>
                            <InputText class="form-control text-white px-3 py-2"
                                       style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                       @bind-Value="registerModel.UserName" />
                            <ValidationMessage For="@(() => registerModel.UserName)" class="small mt-1" style="color: #f87171;" />
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Account Password<span style="color: #f87171; font-weight: bold; margin-left: 2px;">*</span></label>
                                <InputText type="password"
                                           class="form-control text-white px-3 py-2"
                                           style="background: #192230 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                           placeholder="••••••••"
                                           @bind-Value="registerModel.Password" />
                                <ValidationMessage For="@(() => registerModel.Password)" class="small mt-1" style="color: #f87171;" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Confirm Secret Key<span style="color: #f87171; font-weight: bold; margin-left: 2px;">*</span></label>
                                <InputText type="password"
                                           class="form-control text-white px-3 py-2"
                                           style="background: #192230 !important; border: 1px solid #2e3d54 !important; border-radius: 8px; font-size: 0.95rem; color: #fff !important;"
                                           placeholder="••••••••"
                                           @bind-Value="registerModel.ConfirmPassword" />
                                <ValidationMessage For="@(() => registerModel.ConfirmPassword)" class="small mt-1" style="color: #f87171;" />
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-5 pt-3 border-top" style="border-color: rgba(255,255,255,0.04) !important;">
                            <button type="button"
                                    class="btn text-white px-4 py-2 rounded-3"
                                    style="background: linear-gradient(180deg, #2a3c54 0%, #192330 100%) !important; border: 1px solid #3d516b !important; font-size: 0.9rem;"
                                    @onclick="BackToLogin">
                                Back To Login
                            </button>

                            <button type="submit"
                                    class="btn text-white fw-medium px-4 py-2 rounded-3"
                                    style="background: linear-gradient(180deg, #1e2d42 0%, #111a26 100%) !important;
                                border: 1px solid #00d2ff !important;
                                box-shadow: 0 0 15px rgba(0, 210, 255, 0.25) !important;
                                font-size: 0.9rem;">
                                Register
                            </button>
                        </div>

                    </EditForm>

                </div>

            </div>

        </div>
    </div>

    <footer class="w-100 d-flex justify-content-between align-items-center px-4 py-3 text-muted position-absolute bottom-0 start-0"
            style="font-size: 0.75rem; color: #4b596c !important; border-top: 1px solid rgba(255,255,255,0.02) !important;">
        <div>
            Enterprise Edition | © 2026 EMS Corp. All rights reserved.
        </div>
        <div style="color: #4b596c;">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 0l6 8-6 8-6-8z" />
            </svg>
        </div>
    </footer>
</div>