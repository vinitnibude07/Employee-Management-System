@page "/forgotpassword"
@rendermode InteractiveServer

@using EMS.Shared.DTOs
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Json

@inject HttpClient Http
@inject NavigationManager Navigation

<!-- Main Page Container with Dark Gradient Background matching the theme -->
<div class="container-fluid min-vh-100 d-flex flex-column justify-content-center align-items-center position-relative p-3"
     style="background: radial-gradient(circle at center, #1a2332 0%, #0d1117 100%) !important; font-family: 'Segoe UI', system-ui, sans-serif;">

    <div class="row justify-content-center w-100 my-auto">
        <div class="col-md-6 col-lg-4" style="max-width: 440px;">

            <!-- Metallic Central Card Container with Cyan Border Glow Accent -->
            <div class="card border-0 rounded-4 shadow-2xl overflow-hidden shadow-lg"
                 style="background: linear-gradient(145deg, #232d3f 0%, #151b26 100%) !important;
                box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.7), inset 0 1px 1px rgba(255,255,255,0.1) !important;
                border: 1px solid rgba(0, 210, 255, 0.15) !important;">

                <div class="card-body p-5" style="background: transparent !important;">

                    <!-- Dynamic Header Section based on Wizard State -->
                    <div class="text-center mb-4">
                        <h2 class="fw-bold text-white mb-2" style="letter-spacing: 0.5px; text-shadow: 0 2px 10px rgba(0,0,0,0.5); font-size: 1.85rem;">
                            @if (!otpSent)
                            {
                                <span>Recover Account</span>
                            }
                            else
                            {
                                <span>Reset Password</span>
                            }
                        </h2>
                        <p class="text-muted small" style="letter-spacing: 0.3px; color: #788fa6 !important;">
                            @if (!otpSent)
                            {
                                <span>Enter your registered email to request a secure OTP</span>
                            }
                            else
                            {
                                <span>Verification code accepted. Choose a secure combination</span>
                            }
                        </p>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(message))
                    {
                        <div class="alert border-0 small rounded-3 mb-4 text-center"
                             style="background: rgba(0, 210, 255, 0.1); color: #00d2ff; border: 1px solid rgba(0, 210, 255, 0.2) !important;" role="alert">
                            🖧 System: @message
                        </div>
                    }

                    @if (!otpSent)
                    {
                        <!-- STEP 1: REQUEST OTP FORM -->
                        <EditForm Model="@model"
                                  OnValidSubmit="SendOtp"
                                  FormName="ForgotPasswordForm">

                            <DataAnnotationsValidator />
                            <div class="small text-danger mb-3"><ValidationSummary /></div>

                            <div class="mb-4">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Email Address</label>
                                <InputText class="form-control text-white px-3 py-2.5"
                                           style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 10px; font-size: 0.95rem; color: #fff !important;"
                                           placeholder="name@company.com"
                                           @bind-Value="@model.Email" />
                            </div>

                            <!-- Glowing Action Button Option -->
                            <div class="d-grid mt-5">
                                <button type="submit"
                                        class="btn fw-medium text-white py-2.5 rounded-3"
                                        style="background: linear-gradient(180deg, #1e2d42 0%, #111a26 100%) !important;
                                    border: 1px solid #00d2ff !important;
                                    box-shadow: 0 0 15px rgba(0, 210, 255, 0.25) !important;
                                    font-size: 1rem; letter-spacing: 0.5px;">
                                    Send Verification OTP
                                </button>
                            </div>

                        </EditForm>
                    }
                    else
                    {
                        <!-- STEP 2: VERIFY AND SUBMIT RESET -->
                        <EditForm Model="@resetModel"
                                  OnValidSubmit="ResetUserPassword"
                                  FormName="ResetPasswordForm">

                            <DataAnnotationsValidator />
                            <div class="small text-danger mb-3"><ValidationSummary /></div>

                            <div class="mb-3">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Enter One-Time PIN (OTP)</label>
                                <InputText class="form-control text-white px-3 py-2.5 text-center fw-bold"
                                           style="background: #111722 !important; border: 1px solid #2e3d54 !important; border-radius: 10px; font-size: 1.1rem; letter-spacing: 4px; color: #00d2ff !important;"
                                           placeholder="000000"
                                           @bind-Value="@resetModel.Otp" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">New Security Password</label>
                                <InputText class="form-control text-white px-3 py-2.5"
                                           type="password"
                                           style="background: #192230 !important; border: 1px solid #2e3d54 !important; border-radius: 10px; font-size: 0.95rem; color: #fff !important;"
                                           placeholder="••••••••"
                                           @bind-Value="@resetModel.NewPassword" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label small fw-medium mb-2" style="color: #94a3b8;">Confirm New Password</label>
                                <InputText class="form-control text-white px-3 py-2.5"
                                           type="password"
                                           style="background: #192230 !important; border: 1px solid #2e3d54 !important; border-radius: 10px; font-size: 0.95rem; color: #fff !important;"
                                           placeholder="••••••••"
                                           @bind-Value="@resetModel.ConfirmPassword" />
                            </div>

                            <!-- Glowing Action Button Option -->
                            <div class="d-grid mt-5">
                                <button type="submit"
                                        class="btn fw-medium text-white py-2.5 rounded-3"
                                        style="background: linear-gradient(180deg, #1e2d42 0%, #111a26 100%) !important;
                                    border: 1px solid #00d2ff !important;
                                    box-shadow: 0 0 15px rgba(0, 210, 255, 0.25) !important;
                                    font-size: 1rem; letter-spacing: 0.5px;">
                                    Commit Password Change
                                </button>
                            </div>

                        </EditForm>
                    }

                    <!-- Core Context Action Link Back -->
                    <div class="text-center mt-4 pt-2">
                        <a href="/" class="text-decoration-none small text-muted" style="transition: color 0.2s;">
                            ← Back to Authentication Entry
                        </a>
                    </div>

                </div>

            </div>

        </div>
    </div>

    <!-- Page Global Theme Footer -->
    <footer class="w-100 d-flex justify-content-between align-items-center px-4 py-3 text-muted position-absolute bottom-0 start-0"
            style="font-size: 0.75rem; color: #4b596c !important; border-top: 1px solid rgba(255,255,255,0.02) !important;">
        <div>
            Enterprise Edition | © 2026 EMS Corp. All rights reserved.
        </div>
        <div style="color: #4b596c;">
            <svg width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M8 0l6 8-6 8-6-8z" />
            </svg>
        </div>
    </footer>
</div>
