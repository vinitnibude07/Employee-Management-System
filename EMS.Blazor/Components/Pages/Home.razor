@page "/"
@page "/home"
@rendermode InteractiveServer

<div class="container-fluid p-4 text-white min-vh-100" style="background: radial-gradient(circle at top right, #161f30 0%, #0d1117 100%); font-family: 'Segoe UI', system-ui, sans-serif;">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom pb-4 mb-4" style="border-color: rgba(255,255,255,0.05) !important;">
        <div>
            <h1 class="fw-bold tracking-tight mb-1" style="font-size: 1.75rem; text-shadow: 0 2px 10px rgba(0,0,0,0.3);">
                Workspace Dashboard
            </h1>
            <p class="small mb-0" style="color: #a4b5c6 !important;">
                @if (IsLoggedIn)
                {
                    <span>Welcome back! Administrative node access granted.</span>
                }
                else
                {
                    <span>Welcome to the Employee Management Portal. Please sign in to manage operations.</span>
                }
            </p>
        </div>

        <div class="mt-3 mt-md-0 d-flex align-items-center gap-3">
            @if (IsLoggedIn)
            {
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-dark bg-opacity-40 px-3 py-2 rounded-2 border border-secondary border-opacity-10 text-info fw-bold d-flex align-items-center gap-2">
                        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor" class="text-secondary">
                            <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0z" />
                            <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8zm8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1z" />
                        </svg>
                        @CurrentUser
                    </span>

                    <button type="button" @onclick="LogOut" class="btn btn-sm btn-outline-danger px-3 rounded-2 fw-medium d-flex align-items-center gap-2" style="height: 38px; border-color: rgba(220, 38, 38, 0.35);">
                        <i class="bi bi-box-arrow-right"></i> Log Out
                    </button>
                </div>
            }
            else
            {
                <button type="button" @onclick="NavigateToLogin" class="btn btn-sm px-3 py-2 btn-outline-info rounded-2 fw-medium transition-all" style="box-shadow: 0 0 10px rgba(0, 210, 255, 0.15);">
                    <i class="bi bi-box-arrow-in-right me-1"></i> Log In
                </button>
                <button type="button" @onclick="NavigateToRegister" class="btn btn-sm px-3 py-2 btn-info text-dark rounded-2 fw-medium transition-all" style="box-shadow: 0 4px 12px rgba(0, 210, 255, 0.35);">
                    <i class="bi bi-person-plus me-1"></i> New Registration
                </button>
            }
        </div>
    </div>

    <div class="row align-items-center my-5 py-2">
        <div class="col-lg-6 mb-4 mb-lg-0">
            <span class="badge bg-info bg-opacity-10 text-info px-3 py-2 rounded-pill mb-3 tracking-wider fw-bold text-uppercase" style="font-size: 0.75rem; border: 1px solid rgba(0,210,255,0.15);">
                Employee Management System
            </span>
            <h2 class="fw-bold text-white display-6 mb-3">Secure Core Workspace</h2>
            <p class="lead mb-4" style="color: #a4b5c6 !important; font-size: 1.1rem; line-height: 1.6;">
                An advanced administrative node engineered for comprehensive workforce coordination, credential validation, and structural sync matrices.
            </p>
            <div class="row g-3">
                <div class="col-sm-6">
                    <div class="d-flex align-items-center gap-2 text-white-50 small">
                        <i class="bi bi-shield-check text-info fs-5"></i>
                        <span>Role-Based Encryption Controls</span>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="d-flex align-items-center gap-2 text-white-50 small">
                        <i class="bi bi-lightning-charge text-info fs-5"></i>
                        <span>Real-Time Directory Sync</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 text-center">
            <div class="position-relative d-inline-block">
                <div class="position-absolute top-50 start-50 translate-middle bg-info rounded-circle opacity-10 blur-3xl" style="width: 300px; height: 300px; filter: blur(80px);"></div>
                <svg width="100%" height="280" viewBox="0 0 500 300" fill="none" xmlns="http://www.w3.org/2000/svg" style="max-width: 460px;">
                    <rect x="40" y="40" width="420" height="220" rx="16" fill="#111622" stroke="#233145" stroke-width="2" />
                    <circle cx="65" cy="65" r="5" fill="#ef4444" />
                    <circle cx="80" cy="65" r="5" fill="#f59e0b" />
                    <circle cx="95" cy="65" r="5" fill="#10b981" />
                    <rect x="70" y="100" width="160" height="12" rx="4" fill="#1e293b" />
                    <rect x="70" y="124" width="220" height="8" rx="4" fill="#141b2e" />
                    <rect x="70" y="140" width="120" height="8" rx="4" fill="#141b2e" />
                    <rect x="320" y="95" width="110" height="110" rx="12" fill="#162235" stroke="rgba(0,210,255,0.2)" stroke-width="1.5" />
                    <circle cx="375" cy="150" r="30" stroke="#1e293b" stroke-width="6" fill="none" />
                    <path d="M375 120 C400 120, 405 145, 405 150" stroke="#00d2ff" stroke-width="6" stroke-linecap="round" fill="none" />
                    <line x1="120" y1="190" x2="280" y2="190" stroke="#233145" stroke-width="2" />
                    <circle cx="120" cy="190" r="6" fill="#00d2ff" />
                    <circle cx="200" cy="190" r="6" fill="#10b981" />
                    <circle cx="280" cy="190" r="6" fill="#3b82f6" />
                </svg>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-md-4">
            <div class="card h-100 border-0 rounded-3 p-3 position-relative overflow-hidden"
                 style="background: linear-gradient(145deg, #182232 0%, #111622 100%); border: 1px solid rgba(0,210,255,0.1) !important; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="small fw-bold text-uppercase tracking-wider" style="color: #a4b5c6 !important;">Total Employees</span>
                    <div class="p-2 rounded-2 bg-info bg-opacity-10 text-info"><i class="bi bi-people fs-5"></i></div>
                </div>
                <h3 class="fw-bold mb-1 text-white">@TotalEmployeesCount</h3>
                <span class="text-muted small">Registered in database list</span>
                <div class="position-absolute bottom-0 start-0 end-0" style="height: 3px; background: linear-gradient(90deg, transparent, #00d2ff, transparent);"></div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card h-100 border-0 rounded-3 p-3 position-relative overflow-hidden"
                 style="background: linear-gradient(145deg, #182232 0%, #111622 100%); border: 1px solid rgba(0,210,255,0.1) !important; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="small fw-bold text-uppercase tracking-wider" style="color: #a4b5c6 !important;">Active Employees</span>
                    <div class="p-2 rounded-2 bg-success bg-opacity-10 text-success"><i class="bi bi-person-check fs-5"></i></div>
                </div>
                <h3 class="fw-bold mb-1 text-white">@ActiveEmployeesCount</h3>
                <span class="text-muted small">Current active list metrics</span>
                <div class="position-absolute bottom-0 start-0 end-0" style="height: 3px; background: linear-gradient(90deg, transparent, #10b981, transparent);"></div>
            </div>
        </div>

        <div class="col-12 col-md-4">
            <div class="card h-100 border-0 rounded-3 p-3 position-relative overflow-hidden"
                 style="background: linear-gradient(145deg, #182232 0%, #111622 100%); border: 1px solid rgba(0,210,255,0.1) !important; box-shadow: 0 10px 30px rgba(0,0,0,0.3);">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="small fw-bold text-uppercase tracking-wider" style="color: #a4b5c6 !important;">Departments</span>
                    <div class="p-2 rounded-2 bg-warning bg-opacity-10 text-warning"><i class="bi bi-diagram-3 fs-5"></i></div>
                </div>
                <h3 class="fw-bold mb-1 text-white">@DepartmentCount</h3>
                <span class="text-muted small">Operational sectors defined</span>
                <div class="position-absolute bottom-0 start-0 end-0" style="height: 3px; background: linear-gradient(90deg, transparent, #f59e0b, transparent);"></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12">
            <div class="card border-0 rounded-3 p-4" style="background: #111622; border: 1px solid rgba(255,255,255,0.05) !important; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
                <h4 class="fw-bold mb-3 small text-uppercase tracking-wider" style="color: #00d2ff;">Available Operations</h4>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <button type="button" @onclick='() => SecureNavigateTo("employeelist")'
                                class="btn w-100 py-3 text-start px-3 d-flex align-items-center justify-content-between rounded-3 text-white"
                                style="background: #182232; border: 1px solid #233145; cursor: pointer;">
                            <div>
                                <h6 class="fw-bold mb-0 text-white">Browse Employee Directory</h6>
                                <small style="color: #a4b5c6 !important; font-size: 0.8rem;">Access data records and operational systems</small>
                            </div>
                            <i class="bi bi-arrow-right-short fs-4 text-info"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>